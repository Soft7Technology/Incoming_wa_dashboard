{
  "info": {
    "name": "Console API - Meta WhatsApp Business",
    "description": "Complete API collection for Console API - WhatsApp Business API management service\n\n**Authentication:**\n- x-api-key: Your API key from onboarding\n- x-company-key: Your company key from onboarding\n\n**Base URL:** {{base_url}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "console-api-v1"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "value",
        "value": "{{api_key}}",
        "type": "string"
      },
      {
        "key": "key",
        "value": "x-api-key",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Company Management",
      "item": [
        {
          "name": "Onboard Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('company_id', response.data.id);",
                  "    pm.environment.set('api_key', response.data.api_key);",
                  "    pm.environment.set('company_key', response.data.company_key);",
                  "    pm.environment.set('webhook_verify_token', response.data.webhook_verify_token);",
                  "    console.log('✅ Saved: company_id, api_key, company_key');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Company\",\n  \"email\": \"test@company.com\",\n  \"phone\": \"+1234567890\",\n  \"business_id\": \"meta_business_id\",\n  \"webhook_url\": \"https://webhook.site/unique-url\",\n  \"initial_credit\": 100.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/companies",
              "host": ["{{base_url}}"],
              "path": ["companies"]
            },
            "description": "Onboard a new company. Returns api_key and company_key - save these!"
          },
          "response": []
        },
        {
          "name": "Get Company by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-company-key",
                "value": "{{company_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/companies/{{company_id}}",
              "host": ["{{base_url}}"],
              "path": ["companies", "{{company_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Companies",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-company-key",
                "value": "{{company_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/companies",
              "host": ["{{base_url}}"],
              "path": ["companies"]
            }
          },
          "response": []
        },
        {
          "name": "Update Company",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-company-key",
                "value": "{{company_key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Company Name\",\n  \"webhook_url\": \"https://new-webhook.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/companies/{{company_id}}",
              "host": ["{{base_url}}"],
              "path": ["companies", "{{company_id}}"]
            }
          },
          "response": []
        }
      ]
    },
